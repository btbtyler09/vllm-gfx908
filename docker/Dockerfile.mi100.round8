# Round-8 thin overlay bake: COPY the B4 W4 MoE config JSON for
# Qwen3.5-122B-A10B-GPTQ-4bit (E=256, N=256 per-rank shape on TP=4) into the
# existing v0.20 image. No source rebuild needed — config files are loaded at
# MoE layer init time.
#
# Build (run from the vllm-gfx908 repo root):
#   docker build -t btbtyler09/vllm-rocm-gfx908:v0.20.0rc1.dev \
#                -t btbtyler09/vllm-rocm-gfx908:latest \
#                -f docker/Dockerfile.mi100.round8 .
#
# Round-8 B4 W4 MoE config tune for Qwen3.5-122B-A10B-GPTQ-4bit @ TP=4
# (per-rank intermediate N=256 after TP=4 sharding + W4 packing):
#  * c=1 Single User Latency:  +12.3% tok/s vs default heuristic
#  * c=1 Decode Stress:        +13.1% tok/s
#  * c=32 throughput:          +32.1% tok/s
#  * c=64 throughput:          +1.9%   tok/s
#  * c=128 throughput:         +2.1%   tok/s
#  * c=2..c=16 throughput:     -3.7% to -20.3% (worst at c=16)
# Net positive for single-user / interactive workloads (the typical MI100
# deployment). Batch serving in the c=4-16 range can opt out by either:
#   (a) setting VLLM_TUNED_CONFIG_FOLDER=/path/with/no/such/file
#   (b) deleting the JSON file at runtime
# (Both fall back to vLLM's default heuristic.)
ARG BASE_IMAGE=btbtyler09/vllm-rocm-gfx908:v0.20.0rc1.dev
ARG PYTHON_VERSION=3.12

FROM ${BASE_IMAGE}
ARG PYTHON_VERSION

# COPY the whole MoE configs/ dir over the existing one. Docker's COPY uses
# Go-style glob parsing, and the [Instinct_MI100] brackets in the target
# filename trigger character-class expansion if we name the file directly.
# Copying the directory sidesteps that.
COPY vllm/model_executor/layers/fused_moe/configs \
     /usr/local/lib/python${PYTHON_VERSION}/dist-packages/vllm/model_executor/layers/fused_moe/configs
